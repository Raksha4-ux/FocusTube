{
  "name": "FocusTube - Block YouTube Shorts",
  "description": "Stay focused by hiding YouTube Shorts and redirecting Shorts links to the homepage.",
  "version": "1.1.0",
  "manifest_version": 3,

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://m.youtube.com/*"
  ],

  "action": {
    "default_title": "FocusTube",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
